---

<section class="min-h-screen flex items-center justify-center pt-20 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <img
      src="/img/LukeFam.webp"
      alt="Luke Herrington"
      width="160"
      height="171"
      class="mx-auto mb-8 rounded-full w-40 h-40 object-cover"
      loading="eager"
    />
    <p class="text-slate-400 font-medium mb-2 tracking-wide uppercase text-sm">
      Luke Herrington
    </p>
    <p class="text-cyan-400 font-medium mb-4 tracking-wide uppercase text-sm">
      Staff Full-Stack Engineer
    </p>
    <h1
      class="text-4xl md:text-6xl lg:text-7xl font-bold text-white leading-tight mb-6"
    >
      Software that works<br />
      <span class="text-gradient-brand"> the way your brain does. </span>
    </h1>
    <p
      class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed"
    >
      I replace one-size-fits-all SaaS with affordable, bespoke internal tools
      that mirror your team's unique workflows and mental models.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#work"
        class="bg-gradient-brand text-slate-900 px-8 py-3 rounded-lg font-semibold hover:opacity-90 transition-opacity"
      >
        See My Work
      </a>
      <a
        href="#problems"
        class="border border-slate-700 text-slate-300 px-8 py-3 rounded-lg font-semibold hover:border-slate-500 transition-colors"
      >
        Learn More
      </a>
    </div>
  </div>
</section>
